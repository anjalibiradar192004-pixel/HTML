/*
  RightHandSideMenu (modern)
  - Shows a compact right-hand dashboard for paying customers
  - 100% aligned with reference design
*/

(function () {
  if (window.RightHandSideMenu) {
    return;
  }
  var RightHandSideMenu = {
    _initializing: null,
    _rendered: false,
    _styleId: 'rhs-menu-modern-style',
    _listenerAttached: {},
    _apiDataLoaded: false,
    _sharedApiListenerAttached: false,
    _cacheKey: 'rhs-menu-api-cache'
  };

  // Get user profile picture
  RightHandSideMenu._getUserProfilePicture = function () {
    if (typeof UserSession !== 'undefined' && typeof UserSession.getCachedProfilePictureUrl === 'function') {
      return UserSession.getCachedProfilePictureUrl();
    }
    return null;
  };

  // Extract minimal UI data from full API response
  RightHandSideMenu._extractMinimalUIData = function (data) {
    // Format tokens for display (store formatted value, not raw number)
    var tokensFormatted = null;
    if (data.tokens !== null && data.tokens !== undefined) {
      if (typeof SharedAPI !== 'undefined' && typeof SharedAPI.formatTokens === 'function') {
        tokensFormatted = SharedAPI.formatTokens(data.tokens);
      } else {
        tokensFormatted = String(data.tokens);
      }
    }
    var minimal = {
      xp: data.xp !== null && data.xp !== undefined ? data.xp : null,
      streaks: data.streaks !== null && data.streaks !== undefined ? data.streaks : null,
      tokens: tokensFormatted,
      // Store formatted value for display
      challenges: data.challenges !== null && data.challenges !== undefined ? data.challenges : null
    };
    if (data.activity) {
      minimal.activity = {
        lessonsCount: data.activity.lessonsCount !== null && data.activity.lessonsCount !== undefined ? data.activity.lessonsCount : null,
        exercisesCount: data.activity.exercisesCount !== null && data.activity.exercisesCount !== undefined ? data.activity.exercisesCount : null,
        quizCount: data.activity.quizCount !== null && data.activity.quizCount !== undefined ? data.activity.quizCount : null,
        topics: null
      };

      // Extract minimal topic data (only what's needed for progress bars)
      if (data.activity.topics && _typeof(data.activity.topics) === 'object') {
        minimal.activity.topics = {};
        Object.keys(data.activity.topics).forEach(function (topicId) {
          var topic = data.activity.topics[topicId];
          minimal.activity.topics[topicId] = {
            topicName: topic.topicName || null,
            lessonsScore: topic.lessonsScore !== null && topic.lessonsScore !== undefined ? topic.lessonsScore : 0,
            lessonsTotal: topic.lessonsTotal !== null && topic.lessonsTotal !== undefined ? topic.lessonsTotal : 1,
            lessonInteractionUts: topic.lessonInteractionUts !== null && topic.lessonInteractionUts !== undefined ? topic.lessonInteractionUts : 0,
            lessonRelPath: topic.lessonRelPath || null
          };
        });
      }
    } else {
      minimal.activity = null;
    }
    return minimal;
  };

  // Get cached API data from sessionStorage
  RightHandSideMenu._getCachedAPIData = function () {
    try {
      var cached = sessionStorage.getItem(RightHandSideMenu._cacheKey);
      if (cached) {
        return JSON.parse(cached);
      }
    } catch (e) {
      // Silently fail if sessionStorage is unavailable or data is corrupted
    }
    return null;
  };

  // Save minimal API data to sessionStorage cache
  RightHandSideMenu._saveCachedAPIData = function (data) {
    try {
      var minimal = RightHandSideMenu._extractMinimalUIData(data);
      sessionStorage.setItem(RightHandSideMenu._cacheKey, JSON.stringify(minimal));
    } catch (e) {
      // Silently fail if sessionStorage is unavailable
    }
  };

  // HTML render
  RightHandSideMenu._render = function (wrapper) {
    // Get initial values from cache and known sources BEFORE rendering
    var cachedData = RightHandSideMenu._getCachedAPIData();

    // Get quick stats from known sources first (XP, tokens, streaks), fallback to cache
    var initialXp = 0;
    var initialW3points = null; // Use null to track if we got a value (could be 0 or formatted string)
    var initialLightning = 0;

    // Try known sources first (fastest)
    if (typeof TopNavBar !== 'undefined' && TopNavBar.mylUserLiteState) {
      if (typeof TopNavBar.mylUserLiteState.xp === 'number') initialXp = TopNavBar.mylUserLiteState.xp;
      if (typeof TopNavBar.mylUserLiteState.w3points !== 'undefined') {
        // Format tokens from TopNavBar (same as cache stores formatted)
        var rawTokens = TopNavBar.mylUserLiteState.w3points;
        if (typeof SharedAPI !== 'undefined' && typeof SharedAPI.formatTokens === 'function') {
          initialW3points = SharedAPI.formatTokens(rawTokens);
        } else {
          initialW3points = String(rawTokens);
        }
      }
      if (typeof TopNavBar.mylUserLiteState.lightning !== 'undefined') initialLightning = TopNavBar.mylUserLiteState.lightning;
    }
    if (initialXp === 0 && typeof Pathfinder !== 'undefined' && typeof Pathfinder._userXp === 'number') {
      initialXp = Pathfinder._userXp;
    }

    // Fallback to cached data if known sources not available yet
    if (initialXp === 0 && cachedData && cachedData.xp !== null && cachedData.xp !== undefined) {
      initialXp = cachedData.xp;
    }
    if (initialW3points === null && cachedData && cachedData.tokens !== null && cachedData.tokens !== undefined) {
      // Cached tokens are already formatted, use directly
      initialW3points = cachedData.tokens;
    }
    if (initialLightning === 0 && cachedData && cachedData.streaks !== null && cachedData.streaks !== undefined) {
      initialLightning = cachedData.streaks;
    }

    // Default to 0 if still no value
    if (initialW3points === null) initialW3points = '0';

    // Get activity values from cache if available
    var initialLessons = 0;
    var initialExercises = 0;
    var initialQuizzes = 0;
    var initialChallenges = 0;
    if (cachedData && cachedData.activity) {
      if (cachedData.activity.lessonsCount !== null && cachedData.activity.lessonsCount !== undefined) initialLessons = cachedData.activity.lessonsCount;
      if (cachedData.activity.exercisesCount !== null && cachedData.activity.exercisesCount !== undefined) initialExercises = cachedData.activity.exercisesCount;
      if (cachedData.activity.quizCount !== null && cachedData.activity.quizCount !== undefined) initialQuizzes = cachedData.activity.quizCount;
      if (cachedData.challenges !== null && cachedData.challenges !== undefined) initialChallenges = cachedData.challenges;
    }

    // Get avatar - use cached localStorage value if available (same as topnav)
    var userAvatarUrl = null;
    try {
      var cachedPic = localStorage.getItem('profilePicture');
      if (cachedPic) {
        var parts = decodeURIComponent(cachedPic).split('|');
        if (parts.length > 1) {
          userAvatarUrl = parts[1]; // Avatar URL is after the session ID
        }
      }
    } catch (e) {}
    var avatarSrc = userAvatarUrl || '/images/lynx.svg';
    var avatarAlt = userAvatarUrl ? 'User Avatar' : 'Lynx';
    var avatarStyle = userAvatarUrl ? 'object-fit:cover;width:85%;height:85%;border-radius:12px;margin:7.5%;' : 'object-fit:contain;width:100%;height:100%;';

    // Get user name from UIC cookie (available immediately)
    var fullName = UserSession.getFullName();
    if (!fullName && typeof TopNavBar !== 'undefined' && TopNavBar.cachedUserData) {
      if (TopNavBar.cachedUserData.fullName) {
        fullName = TopNavBar.cachedUserData.fullName;
      } else if (TopNavBar.cachedUserData.firstName) {
        fullName = TopNavBar.cachedUserData.firstName;
        if (TopNavBar.cachedUserData.lastName) {
          fullName += ' ' + TopNavBar.cachedUserData.lastName;
        }
      }
    }

    // Get UIC cookie data for PlanBadge
    var subscriptionPlan = 'free';
    var subscriptionPlanTitle = null;
    var fullAccessPlan = false;
    var userIsAcademyStudent = false;
    var userIsAcademyAdmin = false;
    var freeOrClosedPlan = true;
    var planBadgeHtml = '';
    var uicCookieData = UserSession.getUicCookie();
    if (uicCookieData) {
      subscriptionPlan = uicCookieData.plan || 'free';
      fullAccessPlan = uicCookieData.fa === true;
      subscriptionPlanTitle = uicCookieData.planTitle;
      freeOrClosedPlan = ['free', 'closed'].includes(subscriptionPlan);
    }
    if (TopNavBar.cachedUserData && TopNavBar.cachedUserData.groupsMembership) {
      userIsAcademyStudent = UserSession.checkUserIsAcademyStudent(TopNavBar.cachedUserData.groupsMembership);
      userIsAcademyAdmin = UserSession.checkUserIsAcademyAdmin(TopNavBar.cachedUserData.groupsMembership);
    }
    // Generate PlanBadge HTML
    if (typeof PlanBadge !== 'undefined' && typeof PlanBadge.render === 'function') {
      try {
        var planBadgeUrl = null;
        if (userIsOnboarding) {
          planBadgeUrl = MyLearning._dashboardBaseUrl;
        } else if (freeOrClosedPlan) {
          planBadgeUrl = "".concat(MyLearning._orderBaseUrl, "/plans");
        }
        planBadgeHtml = PlanBadge.render({
          userIsOnboarding: userIsOnboarding,
          userPlan: subscriptionPlan,
          hasFullAccess: fullAccessPlan,
          isAcademyStudent: userIsAcademyStudent,
          isAcademyAdmin: userIsAcademyAdmin,
          returnHtml: true,
          url: planBadgeUrl,
          label: subscriptionPlanTitle
        });
      } catch (e) {}
    }
    var container = document.createElement('aside');
    container.className = 'sidebar';
    container.innerHTML = '<header class="profile">' + '<div class="avatar"><img id="rhs-avatar" src="' + avatarSrc + '" alt="' + avatarAlt + '" style="' + avatarStyle + '" /></div>' + '<div class="profile-details">' + '<div class="profile-name-wrapper">' + '<div class="profile-name" id="rhs-name">' + (fullName || '&nbsp;') + '</div>' + (planBadgeHtml ? '<div class="profile-badge">' + planBadgeHtml + '</div>' : '') + '</div>' + '<div class="profile-meta">' + '<a href="' + MyLearning._dashboardBaseUrl + '/profile" class="profile-link">Open profile</a>' + '<span aria-hidden="true" class="chevron">&#8250;</span>' + '</div>' + '</div>' + '</header>' + '<section class="stats">' + '<article class="stat-card">' + '<div class="stat-tooltip stat-tooltip--left" id="rhs-xp-tooltip">Experience Points: You have ' + initialXp + ' XP. Keep learning to earn more!</div>' + '<div class="stat-icon stat-icon--xp">XP</div>' + '<div class="stat-value" id="rhs-xp">' + initialXp + '</div>' + '</article>' + '<article class="stat-card">' + '<div class="stat-tooltip stat-tooltip--left" id="rhs-w3points-tooltip">Credits: You have ' + initialW3points + ' W3Schools Credits to spend on advanced features.</div>' + '<div class="stat-icon stat-icon--streak">W³</div>' + '<div class="stat-value" id="rhs-w3points">' + initialW3points + '</div>' + '</article>' + '<article class="stat-card">' + '<div class="stat-tooltip stat-tooltip--left" id="rhs-lightning-tooltip">Streaks: You have a ' + initialLightning + ' day streaks. Click to share it!</div>' + '<div class="stat-icon stat-icon--boost">' + '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L5 14h6l-1 8L19 10h-6l1-8z" fill="currentColor"/></svg>' + '</div>' + '<div class="stat-value" id="rhs-lightning">' + initialLightning + '</div>' + '</article>' + '</section>' + '<section class="panel rhs-collapsible">' + '<h2 class="panel-title">Activity Score</h2>' + '<div class="activity-grid">' + '<a href="' + MyLearning._w3sBaseUrl + '" class="activity-card-link"><div class="activity-card"><div class="activity-number" id="rhs-lessons">' + initialLessons + '</div><div class="activity-label">Lessons</div></div></a>' + '<a href="' + MyLearning._w3sBaseUrl + '/exercises/index.php" class="activity-card-link"><div class="activity-card"><div class="activity-number" id="rhs-exercises">' + initialExercises + '</div><div class="activity-label">Exercises</div></div></a>' + '<a href="' + MyLearning._w3sBaseUrl + '/quiztest/default.asp" class="activity-card-link"><div class="activity-card"><div class="activity-number" id="rhs-quizzes">' + initialQuizzes + '</div><div class="activity-label">Quizzes</div></div></a>' + '<a href="' + MyLearning._dashboardBaseUrl + '/code-challenges" class="activity-card-link"><div class="activity-card"><div class="activity-number" id="rhs-challenges">' + initialChallenges + '</div><div class="activity-label">Challenges</div></div></a>' + '</div>' + '</section>' + '<section class="panel progress-panel rhs-collapsible">' + '<h2 class="panel-title progress-title">Progress <span class="progress-chevron">&#8250;</span></h2>' + '<div id="rhs-progress-list">' + '<div class="progress-item">' + '<span class="progress-label">DSA</span>' + '<span class="progress-value">0%</span>' + '<div class="progress-bar"><div class="progress-fill" style="--progress:0%;"></div></div>' + '</div>' + '<div class="progress-item">' + '<span class="progress-label">Python</span>' + '<span class="progress-value">0%</span>' + '<div class="progress-bar"><div class="progress-fill" style="--progress:0%;"></div></div>' + '</div>' + '<div class="progress-item">' + '<span class="progress-label">HTML</span>' + '<span class="progress-value">0%</span>' + '<div class="progress-bar"><div class="progress-fill" style="--progress:0%;"></div></div>' + '</div>' + '</div>' + '</section>' +
